# Copy this file to .env and fill in your values

# NeonTech PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# JWT secret key - generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# Face recognition - lower value = stricter matching (0.0 to 1.0)
FACE_MATCH_THRESHOLD=0.6

# Local path where face registration photos are stored
LOCAL_STORAGE_PATH=static/faces

# Students arriving at or after this hour (24h) are marked late
LATE_THRESHOLD_HOUR=8

DEBUG=False
